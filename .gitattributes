# Normalize line endings to LF in the repo, checkout as-is on all platforms
* text=auto eol=lf

# Shell scripts must always be LF (won't run on Linux/macOS with CRLF)
*.sh text eol=lf

# Windows batch files stay CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.zip binary
*.tar.gz binary
*.exe binary
