# Mailly Configuration
# Copy this file to .env and fill in your values

# Server
SERVER_ADDR=127.0.0.1:3000
SERVER_URL=http://localhost:3000

# Frontend dev server proxy target (overrides SERVER_URL for vite)
# VITE_API_URL=http://localhost:3000

# Storage backend: "postgres" or "badger" (default: badger)
STORAGE_BACKEND=badger

# PostgreSQL (only if STORAGE_BACKEND=postgres)
DATABASE_URL=postgresql://mailly:mailly@localhost:5432/mailly?sslmode=disable

# BadgerDB (only if STORAGE_BACKEND=badger)
BADGER_PATH=./data/mailly

# Encryption key for OAuth tokens (32 bytes hex, generate with: openssl rand -hex 32)
ENCRYPTION_KEY=change-me-to-a-random-64-char-hex-string

# JWT secret for session tokens
JWT_SECRET=change-me-to-a-random-string

# Google OAuth2 (Desktop App)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth2 (Desktop App)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
